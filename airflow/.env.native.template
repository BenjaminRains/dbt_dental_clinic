# Native Airflow local config (Phase A). Copy to airflow/.env.native and fill in.
# Not used by mdc/ETL. init-airflow-native.ps1 reads this file.
#
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Generate JWT secret: python -c "import secrets; print(secrets.token_urlsafe(32))"

AIRFLOW__CORE__FERNET_KEY=
# Required by Airflow 3.2+ api-server (JWT signing / logout revocation)
AIRFLOW__API_AUTH__JWT_SECRET=
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_ADMIN_EMAIL=
