[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
pymysql = ">=1.1.1"
sqlalchemy = "==2.0.27"
mysqlclient = "==2.2.4"
pandas = "==2.2.0"
pyarrow = "==14.0.1"
fastparquet = "==2024.2.0"
numpy = "==1.26.4"
numba = "==0.58.1"
scikit-learn = ">=1.5.0"
scipy = "==1.12.0"
matplotlib = "==3.8.2"
seaborn = "==0.13.2"
plotly = "==5.18.0"
openpyxl = "==3.1.2"
xlrd = "==2.0.1"
csvkit = "==1.3.0"
tqdm = ">=4.66.3"
loguru = "==0.7.2"
missingno = "*"
graphviz = "==0.20.1"
jinja2 = ">=3.1.3,<4.0.0"
dask = "==2025.2.0"
requests = ">=2.32.4"
urllib3 = ">=2.7.0"
charset-normalizer = "==3.0.0"
thefuzz = "==0.19.0"
python-Levenshtein = "==0.25.0"
dbt-core = "~=1.10.0"
dbt-postgres = "~=1.10.0"
# dbt-mysql removed: PyPI adapter frozen at 1.7.0; profiles.yml uses postgres only (pymysql/mysqlclient kept for scripts).
# protobuf 6+ required by dbt 1.10 (closes CVE-2026-0994); urllib3 2.7+ via explicit pin below.
# CVE-2026-40192, CVE-2026-42311 — transitive via matplotlib; pin patched release.
pillow = ">=12.2.0"

[dev-packages]
jupyter = "==1.0.0"
jupyter-server = ">=2.20.0"
jupyterlab = ">=4.5.7"
notebook = ">=7.5.6"
tornado = ">=6.5.6"
mistune = ">=3.2.1"
black = ">=26.3.1"
isort = "==5.13.2"
pylint = "==3.0.3"
pytest = "*"


[requires]
python_version = "3.11"

[scripts]
format = "black ."
lint = "pylint src/"
sort-imports = "isort ."
notebook = "jupyter notebook"
test = "pytest"
