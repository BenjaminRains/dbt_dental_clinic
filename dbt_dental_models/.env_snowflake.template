# dbt Snowflake portfolio warehouse (copy to .env_snowflake)
# Used by: mdc dbt … --env snowflake; scripts/snowflake/*.py
#
# Component-scoped (see docs/deployment/ENVIRONMENT_FILES.md).
# Synthetic / demo data only — never put clinic PHI credentials here.
#
# Auth: key-pair preferred (passkey UI logins cannot be used by scripts/dbt).
#   1. Keys under dbt_dental_models/.snowflake/ (gitignored; not an env file)
#   2. Run set_rsa_public_key.sql in Snowsight
#   3. Set SNOWFLAKE_PRIVATE_KEY_PATH below
#
# Demo Postgres for export stays on:
#   etl_pipeline/synthetic_data_generator/.env_demo
# Do not duplicate DEMO_POSTGRES_* or POSTGRES_ANALYTICS_* here.
SNOWFLAKE_ACCOUNT=
# Example: orgname-account
SNOWFLAKE_USER=
SNOWFLAKE_ROLE=TRANSFORMER
SNOWFLAKE_WAREHOUSE=WH_DEMO_XS
SNOWFLAKE_DATABASE=OPENDENTAL_SF
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_SCHEMA_DBT=DBT
SNOWFLAKE_STAGE=DEMO_EXPORT

# Key-pair (preferred)
# Windows example: C:/Users/you/dbt_dental_clinic/dbt_dental_models/.snowflake/rsa_key.p8
SNOWFLAKE_PRIVATE_KEY_PATH=
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# Password auth (optional fallback — often fails when Snowsight uses passkey)
# SNOWFLAKE_PASSWORD=
