# API Clinic Environment Configuration (copy to .env_api_clinic)
# Used by: API (API_ENVIRONMENT=clinic); EC2 systemd uses api/.env (deploy from this file)
# Clinic API: api-clinic.dbtdentalclinic.com — opendental_analytics (PHI, IP-restricted)
#
# RDS password: run `mdc secrets pull clinic` to sync from the RDS master user secret (rds!db-...).
# Do NOT paste the full Secrets Manager JSON into POSTGRES_ANALYTICS_PASSWORD — password only.

API_ENVIRONMENT=clinic

# RDS (opendental_analytics) — host/user from deployment_credentials.json → clinic_database.postgresql
POSTGRES_ANALYTICS_HOST=<RDS_ENDPOINT>
POSTGRES_ANALYTICS_PORT=5432
POSTGRES_ANALYTICS_DB=opendental_analytics
POSTGRES_ANALYTICS_USER=analytics_user
POSTGRES_ANALYTICS_PASSWORD=<sync via mdc secrets pull clinic>
POSTGRES_ANALYTICS_SSLMODE=require
PGSSLMODE=require

# Optional: skip rds:DescribeDBInstances at runtime (API + EC2 dbt live password fetch)
# CLINIC_RDS_MASTER_SECRET_ARN=arn:aws:secretsmanager:us-east-1:ACCOUNT:secret:rds!db-...
# CLINIC_RDS_INSTANCE_ID=dental-clinic-analytics

# API settings
API_CORS_ORIGINS=https://clinic.dbtdentalclinic.com
API_DEBUG=false
API_LOG_LEVEL=info
API_PORT=8000
API_HOST=0.0.0.0

# Generate: scripts\generate_api_key.ps1 -Clinic
CLINIC_API_KEY=<your_clinic_api_key>

# Portal session signing and users source
CLINIC_PORTAL_SESSION_SECRET=<set_strong_random_secret>
CLINIC_PORTAL_USERS_FILE=/home/ec2-user/dbt_dental_clinic/api/clinic-portal-users.json
