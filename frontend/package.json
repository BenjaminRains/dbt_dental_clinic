{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @mdc/portfolio",
    "dev:portfolio": "npm run dev -w @mdc/portfolio",
    "dev:clinic": "npm run dev -w @mdc/clinic",
    "build": "npm run build:portfolio && npm run build:clinic",
    "build:portfolio": "npm run build -w @mdc/portfolio",
    "build:clinic": "npm run build -w @mdc/clinic",
    "type-check": "npm run type-check -w @mdc/portfolio && npm run type-check -w @mdc/clinic",
    "setup": "powershell -ExecutionPolicy Bypass -File scripts/dev-setup.ps1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "~5.7.2",
    "vite": "^6.4.3"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.7",
    "@mui/material": "^6.4.7",
    "axios": "^1.18.1",
    "mermaid": "^10.9.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "^6.30.4",
    "recharts": "^2.15.1",
    "zustand": "^5.0.3"
  },
  "overrides": {
    "@babel/core": ">=7.29.6",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "rollup": "^4.59.0",
    "form-data": "^4.0.6",
    "dompurify": "3.4.11",
    "uuid": "11.1.1",
    "postcss": "8.5.10",
    "picomatch": "4.0.4",
    "yaml": "2.8.3"
  }
}
