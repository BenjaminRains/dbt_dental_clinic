{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ClinicSecretsRead",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret"
      ],
      "Resource": [
        "arn:aws:secretsmanager:us-east-1:412475545187:secret:dental-clinic/database-*",
        "arn:aws:secretsmanager:us-east-1:412475545187:secret:rds!db-*"
      ]
    },
    {
      "Sid": "ClinicAppSecretReconcile",
      "Effect": "Allow",
      "Action": "secretsmanager:PutSecretValue",
      "Resource": "arn:aws:secretsmanager:us-east-1:412475545187:secret:dental-clinic/database-*"
    },
    {
      "Sid": "ClinicRdsMasterSecretLookup",
      "Effect": "Allow",
      "Action": "rds:DescribeDBInstances",
      "Resource": "*"
    }
  ]
}
